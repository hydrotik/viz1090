@@ -0,0 +1,208 @@
+#include "qt/aircraft_overlay.hpp"
+
+#include "geometry/mercator.hpp"
+
+#include <QtCore/QFile>
+#include <QtCore/QFileInfo>
+#include <QtCore/QJsonArray>
+#include <QtCore/QJsonDocument>
+#include <QtCore/QJsonObject>
+#include <QtGui/QBrush>
+#include <QtGui/QColor>
+#include <QtGui/QFont>
+#include <QtGui/QPainter>
+#include <QtGui/QPainterPath>
+#include <QtGui/QPen>
+
+#include <cmath>
+
+namespace qt
+{
+namespace
+{
+double DegToRad(double degrees)
+{
+  static double constexpr kPi = 3.14159265358979323846;
+  return degrees * kPi / 180.0;
+}
+
+QString LabelFor(AircraftOverlay::Aircraft const & aircraft)
+{
+  QString label = aircraft.m_flight.trimmed();
+  if (label.isEmpty())
+    label = aircraft.m_icao;
+
+  if (aircraft.m_altitude > 0)
+    label += QString(" %1").arg(aircraft.m_altitude);
+  if (aircraft.m_speed > 0)
+    label += QString(" %1kt").arg(aircraft.m_speed);
+
+  return label;
+}
+
+bool ReadNumber(QJsonObject const & object, char const * key, double & value)
+{
+  auto const jsonValue = object.value(QLatin1String(key));
+  if (!jsonValue.isDouble())
+    return false;
+  value = jsonValue.toDouble();
+  return true;
+}
+
+int ReadInt(QJsonObject const & object, char const * key)
+{
+  auto const jsonValue = object.value(QLatin1String(key));
+  return jsonValue.isDouble() ? jsonValue.toInt() : 0;
+}
+
+QString ReadString(QJsonObject const & object, char const * key)
+{
+  auto const jsonValue = object.value(QLatin1String(key));
+  return jsonValue.isString() ? jsonValue.toString() : QString();
+}
+}  // namespace
+
+void AircraftOverlay::SetFeedPath(QString const & path)
+{
+  if (m_feedPath == path)
+    return;
+
+  m_feedPath = path;
+  m_lastModified = QDateTime();
+  m_lastSize = -1;
+  m_aircraft.clear();
+}
+
+void AircraftOverlay::ReloadIfChanged()
+{
+  if (m_feedPath.isEmpty())
+    return;
+
+  QFileInfo const info(m_feedPath);
+  if (!info.exists() || !info.isFile())
+  {
+    if (!m_aircraft.empty())
+      m_aircraft.clear();
+    m_lastModified = QDateTime();
+    m_lastSize = -1;
+    return;
+  }
+
+  if (info.lastModified() == m_lastModified && info.size() == m_lastSize)
+    return;
+
+  m_lastModified = info.lastModified();
+  m_lastSize = info.size();
+  Reload();
+}
+
+void AircraftOverlay::Reload()
+{
+  QFile file(m_feedPath);
+  if (!file.open(QIODevice::ReadOnly))
+    return;
+
+  QJsonParseError error;
+  QJsonDocument const document = QJsonDocument::fromJson(file.readAll(), &error);
+  if (error.error != QJsonParseError::NoError || !document.isObject())
+    return;
+
+  QJsonArray const features = document.object().value(QLatin1String("features")).toArray();
+  std::vector<Aircraft> aircraft;
+  aircraft.reserve(static_cast<size_t>(features.size()));
+
+  for (auto const & featureValue : features)
+  {
+    QJsonObject const feature = featureValue.toObject();
+    QJsonObject const geometry = feature.value(QLatin1String("geometry")).toObject();
+    if (geometry.value(QLatin1String("type")).toString() != QLatin1String("Point"))
+      continue;
+
+    QJsonArray const coordinates = geometry.value(QLatin1String("coordinates")).toArray();
+    if (coordinates.size() < 2 || !coordinates[0].isDouble() || !coordinates[1].isDouble())
+      continue;
+
+    Aircraft item;
+    item.m_lon = coordinates[0].toDouble();
+    item.m_lat = coordinates[1].toDouble();
+    if (!mercator::ValidLat(item.m_lat) || !mercator::ValidLon(item.m_lon))
+      continue;
+
+    QJsonObject const properties = feature.value(QLatin1String("properties")).toObject();
+    item.m_icao = ReadString(properties, "icao");
+    item.m_flight = ReadString(properties, "flight");
+    item.m_altitude = ReadInt(properties, "altitude");
+    item.m_speed = ReadInt(properties, "speed");
+    (void)ReadNumber(properties, "track", item.m_track);
+
+    aircraft.push_back(std::move(item));
+  }
+
+  m_aircraft = std::move(aircraft);
+}
+
+void AircraftOverlay::Draw(QPainter & painter, QRect const & viewport, ScreenBase const & screen, double devicePixelRatio,
+                           int drawScale) const
+{
+  if (m_aircraft.empty() || devicePixelRatio <= 0.0)
+    return;
+
+  painter.save();
+  painter.setRenderHint(QPainter::Antialiasing, true);
+
+  QPen markerPen(QColor(0, 25, 30, 220));
+  markerPen.setWidthF(1.4);
+  painter.setPen(markerPen);
+  painter.setBrush(QColor(0, 230, 255, 230));
+
+  QFont labelFont = painter.font();
+  labelFont.setPointSize(drawScale >= 11 ? 12 : 10);
+  labelFont.setBold(true);
+  painter.setFont(labelFont);
+
+  QPen labelPen(QColor(235, 255, 255, 245));
+  QBrush labelBackground(QColor(0, 20, 24, 180));
+  bool const drawLabels = drawScale >= 10;
+
+  for (auto const & aircraft : m_aircraft)
+  {
+    m2::PointD const mercatorPoint = mercator::FromLatLon(aircraft.m_lat, aircraft.m_lon);
+    m2::PointD const devicePoint = screen.GtoP(mercatorPoint);
+    QPointF const point(devicePoint.x / devicePixelRatio, devicePoint.y / devicePixelRatio);
+    if (!viewport.adjusted(-32, -32, 32, 32).contains(point.toPoint()))
+      continue;
+
+    double const angle = DegToRad(aircraft.m_track);
+    QPointF const nose(std::sin(angle) * 10.0, -std::cos(angle) * 10.0);
+    QPointF const left(std::sin(angle + 2.45) * 7.0, -std::cos(angle + 2.45) * 7.0);
+    QPointF const right(std::sin(angle - 2.45) * 7.0, -std::cos(angle - 2.45) * 7.0);
+
+    QPainterPath marker;
+    marker.moveTo(point + nose);
+    marker.lineTo(point + left);
+    marker.lineTo(point + right);
+    marker.closeSubpath();
+    painter.drawPath(marker);
+
+    if (!drawLabels)
+      continue;
+
+    QString const label = LabelFor(aircraft);
+    if (label.isEmpty())
+      continue;
+
+    QRectF const labelRect = painter.fontMetrics().boundingRect(label).adjusted(-5, -3, 5, 3);
+    QRectF const placedLabel(point.x() + 12, point.y() - labelRect.height() - 2, labelRect.width(), labelRect.height());
+    painter.setPen(Qt::NoPen);
+    painter.setBrush(labelBackground);
+    painter.drawRoundedRect(placedLabel, 4, 4);
+    painter.setPen(labelPen);
+    painter.drawText(placedLabel.adjusted(5, 2, -5, -2), Qt::AlignLeft | Qt::AlignVCenter, label);
+    painter.setPen(markerPen);
+    painter.setBrush(QColor(0, 230, 255, 230));
+  }
+
+  painter.restore();
+}
+
+}  // namespace qt
