+#include <utility>
+
+namespace qt
+{
+namespace
+{
+double DegToRad(double degrees)
+{
+  static double constexpr kPi = 3.14159265358979323846;
+  return degrees * kPi / 180.0;
+}
+
+QString LabelFor(AircraftOverlay::Aircraft const & aircraft)
+{
+  QString label = aircraft.m_flight.trimmed();
+  if (label.isEmpty())
+    label = aircraft.m_icao;
+
+  if (aircraft.m_altitude > 0)
+    label += QString(" FL%1").arg(aircraft.m_altitude / 100);
+  if (aircraft.m_speed > 0)
+    label += QString(" %1kt").arg(aircraft.m_speed);
+
+  return label;
+}
+
+QColor AircraftColor(AircraftOverlay::Aircraft const & aircraft)
+{
+  QString const flight = aircraft.m_flight.trimmed().toUpper();
+  if (flight.startsWith(QLatin1String("N")) || flight.startsWith(QLatin1String("RCH")) ||
+      flight.startsWith(QLatin1String("SAM")) || flight.startsWith(QLatin1String("PAT")))
+  {
+    return QColor(255, 168, 42, 242);
+  }
+
+  if (!flight.isEmpty())
+    return QColor(53, 255, 120, 242);
+
+  return QColor(0, 230, 255, 235);
+}
+
+QColor WeatherColor(int intensity)
+{
+  switch (intensity)
+  {
+  case 1: return QColor(30, 205, 60, 82);
+  case 2: return QColor(245, 220, 40, 100);
+  case 3: return QColor(235, 60, 35, 118);
+  case 4: return QColor(210, 55, 210, 140);
+  default: return QColor(0, 0, 0, 0);
+  }
+}
+
+bool ReadNumber(QJsonObject const & object, char const * key, double & value)
+{
+  auto const jsonValue = object.value(QLatin1String(key));
+  if (!jsonValue.isDouble())
+    return false;
+  value = jsonValue.toDouble();
+  return true;
+}
+
+int ReadInt(QJsonObject const & object, char const * key)
+{
+  auto const jsonValue = object.value(QLatin1String(key));
+  return jsonValue.isDouble() ? jsonValue.toInt() : 0;
+}
+
+QString ReadString(QJsonObject const & object, char const * key)
+{
+  auto const jsonValue = object.value(QLatin1String(key));
+  return jsonValue.isString() ? jsonValue.toString() : QString();
+}
+}  // namespace
+
+void AircraftOverlay::SetAircraftFeedPath(QString const & path)
+{
+  if (m_aircraftFeedPath == path)
+    return;
+
+  m_aircraftFeedPath = path;
+  m_aircraftLastModified = QDateTime();
+  m_aircraftLastSize = -1;
+  m_aircraft.clear();
+  m_trails.clear();
+}
+
+void AircraftOverlay::SetWeatherFeedPath(QString const & path)
+{
+  if (m_weatherFeedPath == path)
+    return;
+
+  m_weatherFeedPath = path;
+  m_weatherLastModified = QDateTime();
+  m_weatherLastSize = -1;
+  m_weatherTiles.clear();
+}
+
+void AircraftOverlay::ReloadIfChanged()
+{
+  if (!m_aircraftFeedPath.isEmpty())
+  {
+    QFileInfo const info(m_aircraftFeedPath);
+    if (!info.exists() || !info.isFile())
+    {
+      if (!m_aircraft.empty())
+        m_aircraft.clear();
+      m_aircraftLastModified = QDateTime();
+      m_aircraftLastSize = -1;
+    }
+    else if (info.lastModified() != m_aircraftLastModified || info.size() != m_aircraftLastSize)
+    {
+      m_aircraftLastModified = info.lastModified();
+      m_aircraftLastSize = info.size();
+      ReloadAircraft();
+    }
+  }
+
+  if (!m_weatherFeedPath.isEmpty())
+  {
+    QFileInfo const info(m_weatherFeedPath);
+    if (!info.exists() || !info.isFile())
+    {
+      if (!m_weatherTiles.empty())
+        m_weatherTiles.clear();
+      m_weatherLastModified = QDateTime();
+      m_weatherLastSize = -1;
+    }
+    else if (info.lastModified() != m_weatherLastModified || info.size() != m_weatherLastSize)
+    {
+      m_weatherLastModified = info.lastModified();
+      m_weatherLastSize = info.size();
+      ReloadWeather();
+    }
+  }
+}
+
+void AircraftOverlay::ReloadAircraft()
+{
+  QFile file(m_aircraftFeedPath);
+  if (!file.open(QIODevice::ReadOnly))
+    return;
+
+  QJsonParseError error;
+  QJsonDocument const document = QJsonDocument::fromJson(file.readAll(), &error);
+  if (error.error != QJsonParseError::NoError || !document.isObject())
+    return;
+
+  QJsonArray const features = document.object().value(QLatin1String("features")).toArray();
+  std::vector<Aircraft> aircraft;
+  aircraft.reserve(static_cast<size_t>(features.size()));
+
+  for (auto const & featureValue : features)
+  {
+    QJsonObject const feature = featureValue.toObject();
+    QJsonObject const geometry = feature.value(QLatin1String("geometry")).toObject();
+    if (geometry.value(QLatin1String("type")).toString() != QLatin1String("Point"))
+      continue;
+
+    QJsonArray const coordinates = geometry.value(QLatin1String("coordinates")).toArray();
+    if (coordinates.size() < 2 || !coordinates[0].isDouble() || !coordinates[1].isDouble())
+      continue;
+
+    Aircraft item;
+    item.m_lon = coordinates[0].toDouble();
+    item.m_lat = coordinates[1].toDouble();
+    if (!mercator::ValidLat(item.m_lat) || !mercator::ValidLon(item.m_lon))
+      continue;
+
+    QJsonObject const properties = feature.value(QLatin1String("properties")).toObject();
+    item.m_icao = ReadString(properties, "icao");
+    item.m_flight = ReadString(properties, "flight");
+    item.m_altitude = ReadInt(properties, "altitude");
+    item.m_speed = ReadInt(properties, "speed");
+    (void)ReadNumber(properties, "track", item.m_track);
+
+    aircraft.push_back(item);
+  }
+
+  UpdateTrails(aircraft);
+  m_aircraft = std::move(aircraft);
+}
+
+void AircraftOverlay::ReloadWeather()
+{
+  QFile file(m_weatherFeedPath);
+  if (!file.open(QIODevice::ReadOnly | QIODevice::Text))
+    return;
+
+  std::vector<WeatherTile> tiles;
+  while (!file.atEnd())
+  {
+    QString const line = QString::fromUtf8(file.readLine()).trimmed();
+    if (line.isEmpty() || line.startsWith(QLatin1Char('#')))
+      continue;
+
+    QStringList const fields = line.split(QLatin1Char(','));
+    if (fields.size() < 5)
+      continue;
+
+    bool okLatMin = false;
+    bool okLonMin = false;
+    bool okLatMax = false;
+    bool okLonMax = false;
+    bool okIntensity = false;
+
+    WeatherTile tile;
+    tile.m_latMin = fields[0].toDouble(&okLatMin);
+    tile.m_lonMin = fields[1].toDouble(&okLonMin);
+    tile.m_latMax = fields[2].toDouble(&okLatMax);
+    tile.m_lonMax = fields[3].toDouble(&okLonMax);
+    tile.m_intensity = fields[4].toInt(&okIntensity);
+
+    if (!okLatMin || !okLonMin || !okLatMax || !okLonMax || !okIntensity)
+      continue;
+    if (!mercator::ValidLat(tile.m_latMin) || !mercator::ValidLat(tile.m_latMax) ||
+        !mercator::ValidLon(tile.m_lonMin) || !mercator::ValidLon(tile.m_lonMax) || tile.m_intensity < 1)
+      continue;
+
+    if (tile.m_latMin > tile.m_latMax)
+      std::swap(tile.m_latMin, tile.m_latMax);
+    if (tile.m_lonMin > tile.m_lonMax)
+      std::swap(tile.m_lonMin, tile.m_lonMax);
+
+    tiles.push_back(tile);
+  }
+
+  m_weatherTiles = std::move(tiles);
+}
+
+void AircraftOverlay::UpdateTrails(std::vector<Aircraft> const & aircraft)
+{
+  static size_t constexpr kMaxTrailPoints = 18;
+  std::map<QString, bool> seen;
+
+  for (auto const & item : aircraft)
+  {
+    QString key = item.m_icao.trimmed();
+    if (key.isEmpty())
+      key = item.m_flight.trimmed();
+    if (key.isEmpty())
+      continue;
+
+    seen[key] = true;
+    auto & trail = m_trails[key];
+    if (trail.empty() || std::fabs(trail.back().m_lat - item.m_lat) > 0.00001 ||
+        std::fabs(trail.back().m_lon - item.m_lon) > 0.00001)
+    {
+      trail.push_back(item);
+    }
+
+    while (trail.size() > kMaxTrailPoints)
+      trail.erase(trail.begin());
+  }
+
+  for (auto it = m_trails.begin(); it != m_trails.end();)
+  {
+    if (seen.find(it->first) == seen.end())
+      it = m_trails.erase(it);
+    else
+      ++it;
+  }
+}
+
+void AircraftOverlay::Draw(QPainter & painter, QRect const & viewport, ScreenBase const & screen, double devicePixelRatio,
+                           int drawScale) const
+{
+  if (devicePixelRatio <= 0.0)
+    return;
+
+  painter.save();
+  painter.setRenderHint(QPainter::Antialiasing, true);
+
+  painter.setPen(Qt::NoPen);
+  for (auto const & tile : m_weatherTiles)
+  {
+    QColor const color = WeatherColor(tile.m_intensity);
+    if (color.alpha() == 0)
+      continue;
+
+    m2::PointD const topLeftDevice = screen.GtoP(mercator::FromLatLon(tile.m_latMax, tile.m_lonMin));
+    m2::PointD const bottomRightDevice = screen.GtoP(mercator::FromLatLon(tile.m_latMin, tile.m_lonMax));
+    QRectF rect(QPointF(topLeftDevice.x / devicePixelRatio, topLeftDevice.y / devicePixelRatio),
+                QPointF(bottomRightDevice.x / devicePixelRatio, bottomRightDevice.y / devicePixelRatio));
+    rect = rect.normalized().adjusted(-0.75, -0.75, 0.75, 0.75);
+    if (viewport.intersects(rect.toAlignedRect()))
+    {
+      painter.setBrush(color);
+      painter.drawRect(rect);
+    }
+  }
+
+  QPen trailPen(QColor(0, 238, 255, 118));
+  trailPen.setWidthF(drawScale >= 11 ? 2.0 : 1.4);
+  trailPen.setCapStyle(Qt::RoundCap);
+  trailPen.setJoinStyle(Qt::RoundJoin);
+  painter.setPen(trailPen);
+  painter.setBrush(Qt::NoBrush);
+
+  for (auto const & pair : m_trails)
+  {
+    auto const & trail = pair.second;
+    if (trail.size() < 2)
+      continue;
+
+    QPainterPath path;
+    bool started = false;
+    for (auto const & item : trail)
+    {
+      m2::PointD const devicePoint = screen.GtoP(mercator::FromLatLon(item.m_lat, item.m_lon));
+      QPointF const point(devicePoint.x / devicePixelRatio, devicePoint.y / devicePixelRatio);
+      if (!started)
+      {
+        path.moveTo(point);
+        started = true;
+      }
+      else
+      {
+        path.lineTo(point);
+      }
+    }
+    painter.drawPath(path);
+  }
+
+  QFont labelFont = painter.font();
+  labelFont.setPointSize(drawScale >= 11 ? 13 : 10);
+  labelFont.setBold(true);
+  painter.setFont(labelFont);
+
+  QPen labelPen(QColor(235, 255, 255, 245));
+  QBrush labelBackground(QColor(0, 16, 20, 198));
+  bool const drawLabels = drawScale >= 10;
+
+  for (auto const & aircraft : m_aircraft)
+  {
+    m2::PointD const mercatorPoint = mercator::FromLatLon(aircraft.m_lat, aircraft.m_lon);
+    m2::PointD const devicePoint = screen.GtoP(mercatorPoint);
+    QPointF const point(devicePoint.x / devicePixelRatio, devicePoint.y / devicePixelRatio);
+    if (!viewport.adjusted(-32, -32, 32, 32).contains(point.toPoint()))
+      continue;
+
+    QColor const aircraftColor = AircraftColor(aircraft);
+    QPen markerPen(QColor(0, 18, 22, 235));
+    markerPen.setWidthF(1.6);
+    painter.setPen(markerPen);
+    painter.setBrush(aircraftColor);
+
+    double const angle = DegToRad(aircraft.m_track);
+    double const markerScale = drawScale >= 11 ? 1.25 : 1.0;
+    QPointF const nose(std::sin(angle) * 11.0 * markerScale, -std::cos(angle) * 11.0 * markerScale);
+    QPointF const tail(std::sin(angle + 3.14159265358979323846) * 7.0 * markerScale,
+                       -std::cos(angle + 3.14159265358979323846) * 7.0 * markerScale);
+    QPointF const left(std::sin(angle + 2.25) * 8.5 * markerScale, -std::cos(angle + 2.25) * 8.5 * markerScale);
+    QPointF const right(std::sin(angle - 2.25) * 8.5 * markerScale, -std::cos(angle - 2.25) * 8.5 * markerScale);
+
+    QPainterPath marker;
+    marker.moveTo(point + nose);
+    marker.lineTo(point + left);
+    marker.lineTo(point + tail);
+    marker.lineTo(point + right);
+    marker.closeSubpath();
+    painter.drawPath(marker);
+
+    if (!drawLabels)
+      continue;
+
+    QString const label = LabelFor(aircraft);
+    if (label.isEmpty())
+      continue;
+
+    QRectF const labelRect = painter.fontMetrics().boundingRect(label).adjusted(-5, -3, 5, 3);
+    QRectF const placedLabel(point.x() + 12, point.y() - labelRect.height() - 2, labelRect.width(), labelRect.height());
+    painter.setPen(Qt::NoPen);
+    painter.setBrush(labelBackground);
+    painter.drawRoundedRect(placedLabel, 4, 4);
+    painter.setPen(labelPen);
+    painter.drawText(placedLabel.adjusted(5, 2, -5, -2), Qt::AlignLeft | Qt::AlignVCenter, label);
+  }
+
+  painter.restore();
+}
+
+}  // namespace qt
