+#pragma once
+
+#include "geometry/screenbase.hpp"
+
+#include <QtCore/QDateTime>
+#include <QtCore/QString>
+
+#include <vector>
+
+class QPainter;
+class QRect;
+
+namespace qt
+{
+
+class AircraftOverlay
+{
+public:
+  struct Aircraft
+  {
+    double m_lat = 0.0;
+    double m_lon = 0.0;
+    double m_track = 0.0;
+    int m_altitude = 0;
+    int m_speed = 0;
+    QString m_icao;
+    QString m_flight;
+  };
+
+  void SetFeedPath(QString const & path);
+  bool IsEnabled() const { return !m_feedPath.isEmpty(); }
+  size_t GetAircraftCount() const { return m_aircraft.size(); }
+
+  void ReloadIfChanged();
+  void Draw(QPainter & painter, QRect const & viewport, ScreenBase const & screen, double devicePixelRatio,
+            int drawScale) const;
+
+private:
+  void Reload();
+
+  QString m_feedPath;
+  QDateTime m_lastModified;
+  qint64 m_lastSize = -1;
+  std::vector<Aircraft> m_aircraft;
+};
+
+}  // namespace qt
