+#pragma once
+
+#include "geometry/screenbase.hpp"
+
+#include <QtCore/QDateTime>
+#include <QtCore/QString>
+
+#include <map>
+#include <vector>
+
+class QPainter;
+class QRect;
+
+namespace qt
+{
+
+class AircraftOverlay
+{
+public:
+  struct Aircraft
+  {
+    double m_lat = 0.0;
+    double m_lon = 0.0;
+    double m_track = 0.0;
+    int m_altitude = 0;
+    int m_speed = 0;
+    QString m_icao;
+    QString m_flight;
+  };
+
+  struct WeatherTile
+  {
+    double m_latMin = 0.0;
+    double m_lonMin = 0.0;
+    double m_latMax = 0.0;
+    double m_lonMax = 0.0;
+    int m_intensity = 0;
+  };
+
+  void SetFeedPath(QString const & path) { SetAircraftFeedPath(path); }
+  void SetAircraftFeedPath(QString const & path);
+  void SetWeatherFeedPath(QString const & path);
+  bool IsEnabled() const { return !m_aircraftFeedPath.isEmpty() || !m_weatherFeedPath.isEmpty(); }
+  size_t GetAircraftCount() const { return m_aircraft.size(); }
+  size_t GetWeatherTileCount() const { return m_weatherTiles.size(); }
+
+  void ReloadIfChanged();
+  void Draw(QPainter & painter, QRect const & viewport, ScreenBase const & screen, double devicePixelRatio,
+            int drawScale) const;
+
+private:
+  void ReloadAircraft();
+  void ReloadWeather();
+  void UpdateTrails(std::vector<Aircraft> const & aircraft);
+
+  QString m_aircraftFeedPath;
+  QDateTime m_aircraftLastModified;
+  qint64 m_aircraftLastSize = -1;
+  std::vector<Aircraft> m_aircraft;
+  std::map<QString, std::vector<Aircraft>> m_trails;
+
+  QString m_weatherFeedPath;
+  QDateTime m_weatherLastModified;
+  qint64 m_weatherLastSize = -1;
+  std::vector<WeatherTile> m_weatherTiles;
+};
+
+}  // namespace qt
